# FastAPI
APP_NAME=Privacy Compliance Platform
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=change-this-to-a-long-random-string-in-production
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/privacy_platform
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/privacy_platform

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCS_BUCKET_NAME=privacy-platform-uploads
DLP_ENABLED=False
PUBSUB_ENABLED=False

# AI / Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
AI_ENABLED=True

# SMTP / Alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@privacy-platform.com
ALERT_EMAIL_ENABLED=False
HIGH_RISK_THRESHOLD=71.0
EXCESSIVE_FINDINGS_THRESHOLD=100

# File Upload
MAX_UPLOAD_SIZE_MB=50

# Google OAuth 2.0 (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Frontend URL (for Google OAuth redirect)
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Logging
LOG_LEVEL=INFO
