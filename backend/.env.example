# =============================================================================
# Backend Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# For Docker Compose: these are set in docker-compose.yml instead.
# For local development: set these in backend/.env (gitignored).
#
# For ngrok testing:
#   1. Set NGROK_URL=https://your-subdomain.ngrok-free.app
#   2. Register that URL in Google Cloud Console authorized redirect URIs:
#      https://your-subdomain.ngrok-free.app/api/v1/auth/google/callback
#   3. Start ngrok: ngrok http 80
#   4. Start the app: docker compose up
# =============================================================================

# --- Application Identity ---
APP_NAME=Privacy Compliance Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# --- Security / JWT (Required) ---
# Generate a strong secret: openssl rand -hex 32
SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database (Required) ---
# Use async URL for the main connection, sync URL for Alembic migrations.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/privacy_platform
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/privacy_platform

# --- Google OAuth 2.0 ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add these authorized redirect URIs:
#   - http://localhost:8000/api/v1/auth/google/callback      (local dev)
#   - http://localhost:80/api/v1/auth/google/callback         (Docker / nginx)
#   - https://your-subdomain.ngrok-free.app/api/v1/auth/google/callback (ngrok)
#   - https://your-app.onrender.com/api/v1/auth/google/callback (Render)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Leave empty to auto-generate from request headers (handles ngrok / proxy).
# Only set this if you need a fixed override.
GOOGLE_REDIRECT_URI=

# --- CORS (Required) ---
# Comma-separated list of origins allowed to make cross-origin requests.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:3000

# --- ngrok / Public URL Support ---
# Set NGROK_URL when testing with ngrok.
# Set PUBLIC_URL when deploying behind a custom domain (Render, custom nginx).
# NGROK_URL takes precedence over PUBLIC_URL.
NGROK_URL=
PUBLIC_URL=
SECURE_COOKIES=false

# --- Google Cloud Platform ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCS_BUCKET_NAME=privacy-platform-uploads
DLP_ENABLED=False
PUBSUB_ENABLED=False

# --- AI / Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
AI_ENABLED=True

# --- SMTP / Email Alerts ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@privacy-platform.com
ALERT_EMAIL_ENABLED=False
HIGH_RISK_THRESHOLD=71.0
EXCESSIVE_FINDINGS_THRESHOLD=100

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
REPORT_DIR=./reports
