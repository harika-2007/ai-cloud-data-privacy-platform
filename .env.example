# =============================================================================
# SecureCloud AI — Environment Configuration Example
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# For Docker Compose: these values are automatically picked up by
# docker-compose.yml if you set them in a root .env file.
#
# For ngrok: set NGROK_URL to your ngrok tunnel URL, e.g.:
#   NGROK_URL=https://your-subdomain.ngrok-free.app
# Then register that same URL in Google Cloud Console as an authorized
# redirect URI: https://your-subdomain.ngrok-free.app/api/v1/auth/google/callback
# =============================================================================

# --- Security (Required) ---
# Generate a strong secret: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL (Required) ---
DATABASE_URL=postgresql+asyncpg://privacy_user:privacy_pass_2024@localhost:5432/privacy_platform
DATABASE_SYNC_URL=postgresql://privacy_user:privacy_pass_2024@localhost:5432/privacy_platform

# --- Google OAuth (Optional — disables Google Sign-In if unset) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Cloud Platform (Optional — stubs used when unset) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
DLP_ENABLED=false
GCS_BUCKET_NAME=
PUBSUB_TOPIC_ID=

# --- Ollama AI (Optional — graceful degradation when offline) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_ENABLED=true
AI_ENABLED=true

# --- Application ---
APP_NAME=SecureCloud AI
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# --- CORS ---
# Comma-separated list of allowed origins.
# Include your ngrok URL here when testing with ngrok.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3000,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:3000

# --- ngrok / Public URL Support ---
# Set these when deploying behind ngrok or a custom reverse proxy.
# NGROK_URL takes precedence over PUBLIC_URL.
# NGROK_URL: https://your-subdomain.ngrok-free.app
# PUBLIC_URL: https://your-custom-domain.com
NGROK_URL=
PUBLIC_URL=
SECURE_COOKIES=false

# --- File Uploads ---
UPLOAD_DIR=./uploads
REPORT_DIR=./reports
MAX_UPLOAD_SIZE=52428800
