# ═══════════════════════════════════════════
# SecureCloud AI — Frontend Environment Config
# ═══════════════════════════════════════════
#
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
#
# For Docker Compose: VITE_* vars are provided as build args.
# For Vercel: set these in Vercel Dashboard → Project Settings → Environment Variables.
#
# Note: All VITE_* variables are embedded at build time.
# You must rebuild after changing them.
# ═══════════════════════════════════════════

# --- API ---
# Backend API base URL (with /api/v1 suffix).
# - Leave empty ("") to use relative URLs via nginx proxy (Docker Compose).
# - Set to the full backend URL for standalone deployments (Vercel + Render).
#
# Default for local development with Docker:
# VITE_API_URL=
#
# For local Vite dev server (npm run dev), the Vite proxy handles /api/:
# VITE_API_URL=
#
# For production (Vercel + Render):
# VITE_API_URL=https://your-backend.onrender.com/api/v1
VITE_API_URL=

# --- Google OAuth ---
# Required for Google Sign-In to work. Get this from:
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=
